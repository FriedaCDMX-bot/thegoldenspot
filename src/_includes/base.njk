<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% if title %}{{ title }} &mdash; {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}" />
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <link rel="stylesheet" href="/assets/styles.css" />

  {# ---- Theme: turns the simple dropdown choices in theme.json into design ---- #}
  {% set accentMap = {
    "sage": "#74814f", "blue": "#5a6f9e", "pink": "#c9808f",
    "terracotta": "#a2573f", "lavender": "#8a6fae", "charcoal": "#403d30"
  } %}
  {% set stripeMap = {
    "pink": "#f0c8d0", "blue": "#94a8d2", "sage": "#cfdbb2",
    "lavender": "#c9bce0", "cream": "#e6dcc4", "none": "#ffffff"
  } %}
  {% set fontMap = {
    "script": "'Great Vibes', cursive",
    "flowing": "'Dancing Script', cursive",
    "elegant-serif": "'Playfair Display', Georgia, serif",
    "modern-serif": "'Fraunces', Georgia, serif"
  } %}
  <style>
    :root {
      --accent-theme: {{ accentMap[theme.accent] or accentMap.sage }};
      --stripe-theme: {{ stripeMap[theme.stripes] or stripeMap.pink }};
      --script: {{ fontMap[theme.titleFont] or fontMap.script }};
    }
    /* accent-driven elements follow the chosen accent color */
    .btn { background: var(--accent-theme); border-color: var(--accent-theme); }
    .chip.active { background: var(--accent-theme); border-color: var(--accent-theme); }
    .main-nav a.active { color: var(--accent-theme); }
    .kicker, .post-tag, .section-label { color: var(--accent-theme); }
    .hero h1 a:hover, .post-title a:hover, .post-card a:hover .post-title,
    .pillar h3 a:hover, .footer-nav a:hover, .article-body h2 { color: var(--accent-theme); }
    /* stripe-driven pattern color */
    .photo-header, .pillars, .tile, .img-placeholder {
      --pink: var(--stripe-theme);
    }
  </style>
</head>
<body>
  <header class="site-header">
    <p class="tagline">{{ theme.tagline or site.tagline }}</p>

    <div class="photo-header{% if page.url == '/' %} photo-header-tall{% endif %}">
      <a href="/" aria-label="Back to the home page">
        <img class="header-badge" src="/assets/badge.svg" alt="{{ site.name }}" />
      </a>
    </div>

    <nav class="main-nav">
      <a href="/"{% if page.url == '/' %} class="active"{% endif %}>Home</a>
      <a href="/food/"{% if page.url.startsWith('/food/') %} class="active"{% endif %}>Food</a>
      <a href="/movement/"{% if page.url.startsWith('/movement/') %} class="active"{% endif %}>Movement</a>
      <a href="/thoughts/"{% if page.url.startsWith('/thoughts/') %} class="active"{% endif %}>Thoughts</a>
      <a href="/deep-dive/"{% if page.url.startsWith('/deep-dive/') %} class="active"{% endif %}>The Deep Dive</a>
      <a href="/favorites/"{% if page.url.startsWith('/favorites/') %} class="active"{% endif %}>Favorites</a>
      <a href="/about/"{% if page.url.startsWith('/about/') %} class="active"{% endif %}>About</a>
    </nav>
  </header>

  {{ content | safe }}

  <footer>
    <div class="footer-inner">
      <p class="footer-brand">{{ site.nameHtml | safe }}</p>
      <ul class="footer-nav">
        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/privacy/">Privacy Policy</a></li>
        <li><a href="/terms/">Terms &amp; Conditions</a></li>
        <li><a href="/disclaimer/">Disclaimer</a></li>
      </ul>
      <p class="copyright">&copy; 2026 {{ site.name }}. Personal experience, not medical advice.</p>
    </div>
  </footer>

  <script data-goatcounter="https://izzysaber.goatcounter.com/count"
          async src="//gc.zgo.at/count.js"></script>
</body>
</html>
