---
layout: base.njk
---
<div class="container narrow">
  <article class="article">
    <div class="article-header">
      <p class="kicker">{{ area or section }}</p>
      <h1 class="script-title">{{ title }}</h1>
      <div class="post-meta">{{ page.date | readableDate }} &middot; {{ content | readingTime }}</div>
    </div>

    <div class="article-body">
      {% if image %}
      <figure class="article-img"><img src="{{ image }}" alt="{{ title }}" /></figure>
      {% endif %}
      {{ content | safe }}
      <div class="disclaimer">{{ site.disclaimer }}</div>
    </div>
    {% include "comments.njk" %}
  </article>
</div>
